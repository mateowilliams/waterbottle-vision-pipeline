# Copy this file to .env and adjust the values.
# PostgreSQL connection (host is "db" under Docker Compose, "localhost" locally).
DATABASE_URL=postgresql://app:app@localhost:5432/bottles

# Model artifact served by the API (relative to the project root).
MODEL_ARTIFACT=artifacts/waterbottle_resnet18_v1.pt

# Threshold below which a prediction is considered "low confidence"
# (used by the monitoring dashboard).
LOW_CONF_THRESHOLD=0.60
